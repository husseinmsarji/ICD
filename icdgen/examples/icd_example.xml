<?xml version="1.0" encoding="UTF-8"?>
<icd xmlns="urn:icdgen:icd:1.0" schemaVersion="1.0">
  <metadata>
    <documentId>ICD-FCC-NAV-001</documentId>
    <documentTitle>Flight Control Computer to Navigation System Interface</documentTitle>
    <program>eVTOL-Gen6</program>
    <revision>B</revision>
    <revisionDate>2026-05-01</revisionDate>
    <author>H. Avionics</author>
    <revisionHistory>
      <entry>
        <revision>A</revision>
        <date>2026-02-10</date>
        <author>H. Avionics</author>
        <description>Initial release.</description>
      </entry>
      <entry>
        <revision>B</revision>
        <date>2026-05-01</date>
        <author>H. Avionics</author>
        <description>Grouped signals into packets; added bit-width fields.</description>
      </entry>
    </revisionHistory>
  </metadata>
  <interfaces>
    <interface id="IF-NAV-STATE" busType="ARINC664" dal="A">
      <name>Navigation State Bus</name>
      <sourceLru>NAV-COMPUTER</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-FCC-NAV-001</owningDocument>
      <description>Primary navigation state delivered to the FCC.</description>
      <packets>
        <packet name="POSITION">
          <description>Geodetic position, published at 50 Hz.</description>
          <signals>
            <signal name="latitude" signalType="float64">
              <description>WGS-84 geodetic latitude.</description>
              <updateRateHz>50</updateRateHz>
              <units>deg</units>
              <dataBits>64</dataBits>
              <xmitBits>64</xmitBits>
              <xmitBytes>8</xmitBytes>
              <definition>Positive north of equator.</definition>
              <rangeMin>-90.0</rangeMin>
              <rangeMax>90.0</rangeMax>
            </signal>
            <signal name="longitude" signalType="float64">
              <description>WGS-84 geodetic longitude.</description>
              <updateRateHz>50</updateRateHz>
              <units>deg</units>
              <dataBits>64</dataBits>
              <xmitBits>64</xmitBits>
              <xmitBytes>8</xmitBytes>
              <rangeMin>-180.0</rangeMin>
              <rangeMax>180.0</rangeMax>
            </signal>
          </signals>
        </packet>
        <packet name="STATUS">
          <signals>
            <signal name="nav_valid" signalType="bool">
              <description>Navigation solution validity flag.</description>
              <updateRateHz>50</updateRateHz>
              <units></units>
              <dataBits>1</dataBits>
              <rangeMin>0</rangeMin>
              <rangeMax>1</rangeMax>
            </signal>
            <signal name="nav_mode" signalType="enum">
              <description>Active navigation mode.</description>
              <updateRateHz>10</updateRateHz>
              <units></units>
              <dataBits>3</dataBits>
              <definition>0=GPS,1=INS,2=blended,3=degraded.</definition>
              <rangeMin>0</rangeMin>
              <rangeMax>3</rangeMax>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>
  </interfaces>
</icd>
