<?xml version="1.0" encoding="UTF-8"?>
<!--
  eVTOL Integrated Avionics ICD — Revision C (current).
  Adds the environmental/air-data bus and the motor-telemetry bus; adds a
  VELOCITY packet to navigation and a CELL_HEALTH packet to the battery bus;
  widens the torque limit; tightens the yaw-rate range; removes the aggregate
  bms_fault (superseded by per-cell health). New and modified signals cite the
  AVS change-control ticket that introduced them. Links Rev B as the prior
  revision so the Change Summary Report auto-populates.
  6 interfaces, 8 packets, 33 signals. Schema-valid against urn:icdgen:icd:1.0.
-->
<icd xmlns="urn:icdgen:icd:1.0" schemaVersion="1.0">
  <metadata>
    <documentId>ICD-EVTOL-AVS-200</documentId>
    <documentTitle>eVTOL Integrated Avionics Interface Control Document</documentTitle>
    <program>eVTOL-Gen6</program>
    <revision>C</revision>
    <revisionDate>2026-06-01</revisionDate>
    <author>H. Avionics</author>
    <revisionHistory>
      <entry>
        <revision>A</revision><date>2026-01-15</date><author>H. Avionics</author>
        <description>Initial release: navigation position, rotor command, and battery telemetry buses.</description>
      </entry>
      <entry>
        <revision>B</revision><date>2026-03-22</date><author>H. Avionics</author>
        <description>Added AHRS attitude bus and navigation STATUS packet; widened altitude range; refined rotor scaling; removed state_of_charge.</description>
      </entry>
      <entry>
        <revision>C</revision><date>2026-06-01</date><author>H. Avionics</author>
        <description>Added environmental air-data and motor-telemetry buses; added VELOCITY and CELL_HEALTH packets; widened torque limit; tightened yaw-rate range; removed bms_fault.</description>
      </entry>
    </revisionHistory>
  </metadata>
  <priorRevisions>
    <priorRevision revision="B" source="icd_evtol_revB.xml"/>
  </priorRevisions>
  <interfaces>
    <interface id="IF-NAV-STATE" busType="ARINC664" dal="A">
      <name>Navigation State Bus</name>
      <sourceLru>NAV-COMPUTER</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Primary navigation solution over AFDX VL-101.</description>
      <packets>
        <packet name="POSITION">
          <description>Geodetic position at 50 Hz.</description>
          <signals>
            <signal name="latitude" signalType="float64">
              <description>WGS-84 geodetic latitude.</description>
              <updateRateHz>50</updateRateHz><units>deg</units>
              <dataBits>64</dataBits><xmitBits>64</xmitBits><xmitBytes>8</xmitBytes>
              <definition>Positive north.</definition>
              <rangeMin>-90.0</rangeMin><rangeMax>90.0</rangeMax>
            </signal>
            <signal name="longitude" signalType="float64">
              <description>WGS-84 geodetic longitude.</description>
              <updateRateHz>50</updateRateHz><units>deg</units>
              <dataBits>64</dataBits><xmitBits>64</xmitBits><xmitBytes>8</xmitBytes>
              <definition>Positive east.</definition>
              <rangeMin>-180.0</rangeMin><rangeMax>180.0</rangeMax>
            </signal>
            <signal name="altitude_msl" signalType="float32">
              <description>Altitude above mean sea level.</description>
              <updateRateHz>50</updateRateHz><units>m</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-500.0</rangeMin><rangeMax>8000.0</rangeMax>
              <prTicket>AVS-1042</prTicket>
            </signal>
          </signals>
        </packet>
        <packet name="STATUS">
          <description>Navigation health and mode.</description>
          <signals>
            <signal name="nav_valid" signalType="bool">
              <description>Solution validity flag.</description>
              <updateRateHz>50</updateRateHz><units></units>
              <dataBits>1</dataBits><xmitBits>1</xmitBits>
              <rangeMin>0</rangeMin><rangeMax>1</rangeMax>
              <prTicket>AVS-1048</prTicket>
            </signal>
            <signal name="nav_mode" signalType="enum">
              <description>Active navigation mode.</description>
              <updateRateHz>10</updateRateHz><units></units>
              <dataBits>3</dataBits><xmitBits>3</xmitBits>
              <definition>0=GPS,1=INS,2=blended,3=degraded.</definition>
              <rangeMin>0</rangeMin><rangeMax>3</rangeMax>
              <prTicket>AVS-1048</prTicket>
            </signal>
          </signals>
        </packet>
        <packet name="VELOCITY">
          <description>NED velocity and ground speed at 50 Hz.</description>
          <signals>
            <signal name="vel_north" signalType="float32">
              <description>North velocity component.</description>
              <updateRateHz>50</updateRateHz><units>m/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-100.0</rangeMin><rangeMax>100.0</rangeMax>
              <prTicket>AVS-1101</prTicket>
            </signal>
            <signal name="vel_east" signalType="float32">
              <description>East velocity component.</description>
              <updateRateHz>50</updateRateHz><units>m/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-100.0</rangeMin><rangeMax>100.0</rangeMax>
              <prTicket>AVS-1101</prTicket>
            </signal>
            <signal name="vel_down" signalType="float32">
              <description>Down velocity component, positive descending.</description>
              <updateRateHz>50</updateRateHz><units>m/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-30.0</rangeMin><rangeMax>30.0</rangeMax>
              <prTicket>AVS-1101</prTicket>
            </signal>
            <signal name="ground_speed" signalType="float32">
              <description>Horizontal ground speed magnitude.</description>
              <updateRateHz>50</updateRateHz><units>m/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>0.0</rangeMin><rangeMax>140.0</rangeMax>
              <prTicket>AVS-1101</prTicket>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-FCC-MOTOR-CMD" busType="ARINC429" dal="A">
      <name>Motor Command Bus</name>
      <sourceLru>FLIGHT-CONTROL-COMPUTER</sourceLru>
      <destinationLru>MOTOR-CONTROLLER-1</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Per-rotor commands from the FCC.</description>
      <packets>
        <packet name="ROTOR_CMD">
          <description>Per-rotor commands at 100 Hz.</description>
          <signals>
            <signal name="rotor_speed_cmd" signalType="uint16">
              <description>Commanded rotor speed.</description>
              <updateRateHz>100</updateRateHz><units>rpm</units>
              <dataBits>16</dataBits><xmitBits>19</xmitBits><xmitBytes>3</xmitBytes>
              <scaling>0.25</scaling>
              <definition>0.25 rpm per LSB, BNR (refined resolution).</definition>
              <rangeMin>0</rangeMin><rangeMax>6000</rangeMax>
              <prTicket>AVS-1051</prTicket>
            </signal>
            <signal name="torque_limit" signalType="int16">
              <description>Signed torque limit.</description>
              <updateRateHz>100</updateRateHz><units>N*m</units>
              <dataBits>16</dataBits><xmitBits>19</xmitBits><xmitBytes>3</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-400</rangeMin><rangeMax>500</rangeMax>
              <prTicket>AVS-1110</prTicket>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-AHRS" busType="ARINC429" dal="A">
      <name>Attitude and Heading Reference Bus</name>
      <sourceLru>AHRS-UNIT</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Attitude and body rates at 100 Hz.</description>
      <packets>
        <packet name="ATTITUDE">
          <description>Euler attitude and body angular rates.</description>
          <signals>
            <signal name="roll" signalType="float32">
              <description>Roll angle, right-wing-down positive.</description>
              <updateRateHz>100</updateRateHz><units>deg</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-180.0</rangeMin><rangeMax>180.0</rangeMax>
              <prTicket>AVS-1063</prTicket>
            </signal>
            <signal name="pitch" signalType="float32">
              <description>Pitch angle, nose-up positive.</description>
              <updateRateHz>100</updateRateHz><units>deg</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-90.0</rangeMin><rangeMax>90.0</rangeMax>
              <prTicket>AVS-1063</prTicket>
            </signal>
            <signal name="yaw" signalType="float32">
              <description>Heading, true north reference.</description>
              <updateRateHz>100</updateRateHz><units>deg</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>0.0</rangeMin><rangeMax>360.0</rangeMax>
              <prTicket>AVS-1063</prTicket>
            </signal>
            <signal name="roll_rate" signalType="float32">
              <description>Body roll rate.</description>
              <updateRateHz>100</updateRateHz><units>deg/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-300.0</rangeMin><rangeMax>300.0</rangeMax>
              <prTicket>AVS-1063</prTicket>
            </signal>
            <signal name="pitch_rate" signalType="float32">
              <description>Body pitch rate.</description>
              <updateRateHz>100</updateRateHz><units>deg/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-300.0</rangeMin><rangeMax>300.0</rangeMax>
              <prTicket>AVS-1063</prTicket>
            </signal>
            <signal name="yaw_rate" signalType="float32">
              <description>Body yaw rate (range tightened to measured envelope).</description>
              <updateRateHz>100</updateRateHz><units>deg/s</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-200.0</rangeMin><rangeMax>200.0</rangeMax>
              <prTicket>AVS-1112</prTicket>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-MOTOR-TELEM" busType="ARINC429" dal="B">
      <name>Motor Telemetry Bus</name>
      <sourceLru>MOTOR-CONTROLLER-1</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Per-rotor motor feedback telemetry.</description>
      <packets>
        <packet name="MOTOR_TELEMETRY">
          <description>Motor temperatures, speed feedback, and inverter health.</description>
          <signals>
            <signal name="motor_temp_1" signalType="int16">
              <description>Rotor 1 winding temperature.</description>
              <updateRateHz>20</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-40</rangeMin><rangeMax>200</rangeMax>
              <prTicket>AVS-1120</prTicket>
            </signal>
            <signal name="motor_temp_2" signalType="int16">
              <description>Rotor 2 winding temperature.</description>
              <updateRateHz>20</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-40</rangeMin><rangeMax>200</rangeMax>
              <prTicket>AVS-1120</prTicket>
            </signal>
            <signal name="motor_temp_3" signalType="int16">
              <description>Rotor 3 winding temperature.</description>
              <updateRateHz>20</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-40</rangeMin><rangeMax>200</rangeMax>
              <prTicket>AVS-1120</prTicket>
            </signal>
            <signal name="motor_temp_4" signalType="int16">
              <description>Rotor 4 winding temperature.</description>
              <updateRateHz>20</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-40</rangeMin><rangeMax>200</rangeMax>
              <prTicket>AVS-1120</prTicket>
            </signal>
            <signal name="motor_rpm_fb" signalType="uint16">
              <description>Measured rotor speed feedback.</description>
              <updateRateHz>100</updateRateHz><units>rpm</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.25</scaling>
              <rangeMin>0</rangeMin><rangeMax>6000</rangeMax>
              <prTicket>AVS-1121</prTicket>
            </signal>
            <signal name="inverter_temp" signalType="int16">
              <description>Inverter heatsink temperature.</description>
              <updateRateHz>20</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-40</rangeMin><rangeMax>150</rangeMax>
              <prTicket>AVS-1121</prTicket>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-ENV" busType="CAN" dal="D">
      <name>Environmental and Air Data Bus</name>
      <sourceLru>AIR-DATA-MODULE</sourceLru>
      <destinationLru>NAV-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Outside air data, CAN 2.0B.</description>
      <packets>
        <packet name="AIR_DATA">
          <description>Air temperature, pressure, and barometric altitude.</description>
          <signals>
            <signal name="oat" signalType="int16">
              <description>Outside air temperature.</description>
              <updateRateHz>5</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-60</rangeMin><rangeMax>60</rangeMax>
              <prTicket>AVS-1130</prTicket>
            </signal>
            <signal name="static_pressure" signalType="uint16">
              <description>Static pressure.</description>
              <updateRateHz>5</updateRateHz><units>hPa</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>300</rangeMin><rangeMax>1100</rangeMax>
              <prTicket>AVS-1130</prTicket>
            </signal>
            <signal name="baro_alt" signalType="float32">
              <description>Barometric altitude (29.92 reference).</description>
              <updateRateHz>5</updateRateHz><units>m</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-500.0</rangeMin><rangeMax>8000.0</rangeMax>
              <prTicket>AVS-1130</prTicket>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-BMS-CAN" busType="CAN" dal="C">
      <name>Battery Management Bus</name>
      <sourceLru>BATTERY-MGMT-SYSTEM</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Pack-level battery telemetry, CAN 2.0B.</description>
      <packets>
        <packet name="PACK_TELEMETRY">
          <description>Pack-level telemetry.</description>
          <signals>
            <signal name="pack_voltage" signalType="uint16">
              <description>Pack terminal voltage.</description>
              <updateRateHz>10</updateRateHz><units>V</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.01</scaling>
              <rangeMin>0</rangeMin><rangeMax>900</rangeMax>
            </signal>
            <signal name="pack_current" signalType="int16">
              <description>Pack current, positive on discharge.</description>
              <updateRateHz>10</updateRateHz><units>A</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-600</rangeMin><rangeMax>600</rangeMax>
            </signal>
          </signals>
        </packet>
        <packet name="CELL_HEALTH">
          <description>Per-cell health summary (supersedes aggregate fault flag).</description>
          <signals>
            <signal name="cell_temp_max" signalType="int16">
              <description>Hottest cell temperature.</description>
              <updateRateHz>2</updateRateHz><units>degC</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-40</rangeMin><rangeMax>120</rangeMax>
              <prTicket>AVS-1142</prTicket>
            </signal>
            <signal name="cell_volt_min" signalType="uint16">
              <description>Lowest cell voltage.</description>
              <updateRateHz>2</updateRateHz><units>V</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.001</scaling>
              <rangeMin>0</rangeMin><rangeMax>5</rangeMax>
              <prTicket>AVS-1142</prTicket>
            </signal>
            <signal name="soc_estimate" signalType="uint8">
              <description>State-of-charge estimate (replaces removed state_of_charge).</description>
              <updateRateHz>1</updateRateHz><units>%</units>
              <dataBits>8</dataBits><xmitBits>8</xmitBits><xmitBytes>1</xmitBytes>
              <rangeMin>0</rangeMin><rangeMax>100</rangeMax>
              <prTicket>AVS-1142</prTicket>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>
  </interfaces>
</icd>
