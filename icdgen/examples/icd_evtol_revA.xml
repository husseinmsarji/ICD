<?xml version="1.0" encoding="UTF-8"?>
<!--
  eVTOL Integrated Avionics ICD — Revision A (initial release).
  3 interfaces, 3 packets, 9 signals. Rev A is the baseline, so signals carry
  no AVS change-control tickets (none are expected at initial release).
  Schema-valid against urn:icdgen:icd:1.0.
-->
<icd xmlns="urn:icdgen:icd:1.0" schemaVersion="1.0">
  <metadata>
    <documentId>ICD-EVTOL-AVS-200</documentId>
    <documentTitle>eVTOL Integrated Avionics Interface Control Document</documentTitle>
    <program>eVTOL-Gen6</program>
    <revision>A</revision>
    <revisionDate>2026-01-15</revisionDate>
    <author>H. Avionics</author>
    <revisionHistory>
      <entry>
        <revision>A</revision><date>2026-01-15</date><author>H. Avionics</author>
        <description>Initial release: navigation position, rotor command, and battery telemetry buses.</description>
      </entry>
    </revisionHistory>
  </metadata>
  <interfaces>
    <interface id="IF-NAV-STATE" busType="ARINC664" dal="A">
      <name>Navigation State Bus</name>
      <sourceLru>NAV-COMPUTER</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Primary navigation solution over AFDX VL-101.</description>
      <packets>
        <packet name="POSITION">
          <description>Geodetic position at 50 Hz.</description>
          <signals>
            <signal name="latitude" signalType="float64">
              <description>WGS-84 geodetic latitude.</description>
              <updateRateHz>50</updateRateHz><units>deg</units>
              <dataBits>64</dataBits><xmitBits>64</xmitBits><xmitBytes>8</xmitBytes>
              <definition>Positive north.</definition>
              <rangeMin>-90.0</rangeMin><rangeMax>90.0</rangeMax>
            </signal>
            <signal name="longitude" signalType="float64">
              <description>WGS-84 geodetic longitude.</description>
              <updateRateHz>50</updateRateHz><units>deg</units>
              <dataBits>64</dataBits><xmitBits>64</xmitBits><xmitBytes>8</xmitBytes>
              <definition>Positive east.</definition>
              <rangeMin>-180.0</rangeMin><rangeMax>180.0</rangeMax>
            </signal>
            <signal name="altitude_msl" signalType="float32">
              <description>Altitude above mean sea level.</description>
              <updateRateHz>50</updateRateHz><units>m</units>
              <dataBits>32</dataBits><xmitBits>32</xmitBits><xmitBytes>4</xmitBytes>
              <rangeMin>-500.0</rangeMin><rangeMax>6000.0</rangeMax>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-FCC-MOTOR-CMD" busType="ARINC429" dal="A">
      <name>Motor Command Bus</name>
      <sourceLru>FLIGHT-CONTROL-COMPUTER</sourceLru>
      <destinationLru>MOTOR-CONTROLLER-1</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Per-rotor commands from the FCC.</description>
      <packets>
        <packet name="ROTOR_CMD">
          <description>Per-rotor commands at 100 Hz.</description>
          <signals>
            <signal name="rotor_speed_cmd" signalType="uint16">
              <description>Commanded rotor speed.</description>
              <updateRateHz>100</updateRateHz><units>rpm</units>
              <dataBits>16</dataBits><xmitBits>19</xmitBits><xmitBytes>3</xmitBytes>
              <scaling>0.5</scaling>
              <definition>0.5 rpm per LSB, BNR.</definition>
              <rangeMin>0</rangeMin><rangeMax>6000</rangeMax>
            </signal>
            <signal name="torque_limit" signalType="int16">
              <description>Signed torque limit.</description>
              <updateRateHz>100</updateRateHz><units>N*m</units>
              <dataBits>16</dataBits><xmitBits>19</xmitBits><xmitBytes>3</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-400</rangeMin><rangeMax>400</rangeMax>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>

    <interface id="IF-BMS-CAN" busType="CAN" dal="C">
      <name>Battery Management Bus</name>
      <sourceLru>BATTERY-MGMT-SYSTEM</sourceLru>
      <destinationLru>FLIGHT-CONTROL-COMPUTER</destinationLru>
      <owningDocument>ICD-EVTOL-AVS-200</owningDocument>
      <description>Pack-level battery telemetry, CAN 2.0B.</description>
      <packets>
        <packet name="PACK_TELEMETRY">
          <description>Pack-level telemetry.</description>
          <signals>
            <signal name="pack_voltage" signalType="uint16">
              <description>Pack terminal voltage.</description>
              <updateRateHz>10</updateRateHz><units>V</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.01</scaling>
              <rangeMin>0</rangeMin><rangeMax>900</rangeMax>
            </signal>
            <signal name="pack_current" signalType="int16">
              <description>Pack current, positive on discharge.</description>
              <updateRateHz>10</updateRateHz><units>A</units>
              <dataBits>16</dataBits><xmitBits>16</xmitBits><xmitBytes>2</xmitBytes>
              <scaling>0.1</scaling>
              <rangeMin>-600</rangeMin><rangeMax>600</rangeMax>
            </signal>
            <signal name="state_of_charge" signalType="uint8">
              <description>Estimated state of charge.</description>
              <updateRateHz>1</updateRateHz><units>%</units>
              <dataBits>8</dataBits><xmitBits>8</xmitBits><xmitBytes>1</xmitBytes>
              <rangeMin>0</rangeMin><rangeMax>100</rangeMax>
            </signal>
            <signal name="bms_fault" signalType="bool">
              <description>Aggregate battery fault flag.</description>
              <updateRateHz>10</updateRateHz><units></units>
              <dataBits>1</dataBits><xmitBits>1</xmitBits>
              <rangeMin>0</rangeMin><rangeMax>1</rangeMax>
            </signal>
          </signals>
        </packet>
      </packets>
    </interface>
  </interfaces>
</icd>
