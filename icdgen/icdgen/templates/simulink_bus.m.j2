function icd_bus_objects()
%ICD_BUS_OBJECTS  Auto-generated Simulink.Bus object definitions.
%
{% for line in prov.banner_lines() %}%   {{ line }}
{% endfor %}%
%   Document: {{ model.metadata.document_id }} rev {{ model.metadata.revision }}
%
%   Running this script populates the base workspace with one Simulink.Bus
%   object per ICD packet. Bus element data types and dimensions are derived
%   directly from the ICD signal definitions.

{% for iface in model.interfaces %}
{% for pkt in iface.packets %}
% --- {{ iface.id }} / {{ pkt.name }}  ({{ iface.bus_type }}, DAL {{ iface.dal }}) ---
clear elems;
{% for sig in pkt.signals %}
elems({{ loop.index }}) = Simulink.BusElement;
elems({{ loop.index }}).Name = '{{ sig.name }}';
elems({{ loop.index }}).DataType = '{{ sig.simulink_type }}';
elems({{ loop.index }}).Dimensions = 1;
elems({{ loop.index }}).Unit = '{{ sig.units }}';
elems({{ loop.index }}).Description = '{{ (sig.description or "") | replace("'", "''") }}';
{% endfor %}
{{ packet_bus_name(iface, pkt) }} = Simulink.Bus;
{{ packet_bus_name(iface, pkt) }}.Elements = elems;
assignin('base', '{{ packet_bus_name(iface, pkt) }}', {{ packet_bus_name(iface, pkt) }});

{% endfor %}
{% endfor %}
end
